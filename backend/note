// 💸 frontend/src/pages/Expenses.jsx
// =============================
import { useEffect, useState } from 'react'
import { api } from '../api'
import Chart from '../components/Chart'
export default function Expenses(){
  const [items, setItems] = useState([])
  const [form, setForm] = useState({item:'', amount:'', date:''})
  useEffect(()=>{ api('/api/expenses').then(setItems) },[])
  const add = async ()=>{ const d = await api('/api/expenses',{method:'POST', body: JSON.stringify({...form, amount: Number(form.amount)})}); setItems(i=>[...i,d]); setForm({item:'', amount:'', date:''}) }
  const del = async (id)=>{ await api(`/api/expenses/${id}`,{method:'DELETE'}); setItems(items.filter(i=>i._id!==id)) }
  const data = items.map(i=> ({date:i.date, amount:i.amount}))
  return (
    <div className="grid gap-4">
      <div className="p-4 bg-white rounded-2xl border shadow">
        <div className="font-semibold mb-2">Spending by date</div>
        <Chart data={data} />
      </div>
      <div className="p-4 bg-white rounded-2xl border shadow">
        <div className="font-semibold">Add expense</div>
        <div className="mt-2 grid md:grid-cols-4 gap-2">
          <input className="border p-2 rounded-xl" placeholder="Item" value={form.item} onChange={e=>setForm({...form, item:e.target.value})} />
          <input className="border p-2 rounded-xl" placeholder="Amount" value={form.amount} onChange={e=>setForm({...form, amount:e.target.value})} />
          <input className="border p-2 rounded-xl" type="date" value={form.date} onChange={e=>setForm({...form, date:e.target.value})} />
          <button onClick={add} className="px-4 py-2 rounded-xl bg-black text-white">Add</button>
        </div>
      </div>
      <div className="p-4 bg-white rounded-2xl border shadow">
        <div className="font-semibold">All expenses</div>
        <div className="mt-2 grid gap-2">
          {items.map(i=> (
            <div key={i._id} className="p-2 rounded-xl border flex items-center justify-between">
              <div>
                <div className="font-medium">{i.item}</div>
                <div className="text-sm text-gray-500">₹{i.amount} • {i.date}</div>
              </div>
              <button onClick={()=>del(i._id)} className="px-3 py-1 rounded-xl border">Delete</button>
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}

// =============================
// ✅ frontend/src/pages/Todos.jsx
// =============================
import { useEffect, useState } from 'react'
import { api } from '../api'
export default function Todos(){
  const [items, setItems] = useState([])
  const [title, setTitle] = useState('')
  const [due, setDue] = useState('')
  useEffect(()=>{ api('/api/todos').then(setItems) },[])
  const add = async ()=>{ const d = await api('/api/todos',{method:'POST', body: JSON.stringify({title, due_date: due||null})}); setItems(i=>[d,...i]); setTitle(''); setDue('') }
  const toggle = async (id, done)=>{ await api(`/api/todos/${id}`,{method:'PUT', body: JSON.stringify({done: !done})}); setItems(items.map(i=> i._id===id? {...i, done: !done}: i)) }
  const fav = async (id, favourite)=>{ await api(`/api/todos/${id}`,{method:'PUT', body: JSON.stringify({favourite: !favourite})}); setItems(items.map(i=> i._id===id? {...i, favourite: !favourite}: i)) }
  const del = async (id)=>{ await api(`/api/todos/${id}`,{method:'DELETE'}); setItems(items.filter(i=>i._id!==id)) }
  return (
    <div className="grid gap-4">
      <div className="p-4 bg-white rounded-2xl border shadow">
        <div className="flex gap-2">
          <input className="flex-1 border p-2 rounded-xl" placeholder="New task" value={title} onChange={e=>setTitle(e.target.value)} />
          <input type="date" className="border p-2 rounded-xl" value={due} onChange={e=>setDue(e.target.value)} />
          <button onClick={add} className="px-4 py-2 rounded-xl bg-black text-white">Add</button>
        </div>
      </div>
      <div className="grid gap-2">
        {items.map(i=> (
          <div key={i._id} className={`p-3 rounded-2xl border bg-white shadow flex items-center justify-between ${i.favourite? 'ring-2 ring-yellow-400':''}`}>
            <div>
              <div className="font-medium">{i.title}</div>
              <div className="text-sm text-gray-500">{i.due_date? `Due ${i.due_date}`: 'No due date'}</div>
            </div>
            <div className="flex items-center gap-2">
              <button onClick={()=>fav(i._id, i.favourite)} className="px-3 py-1 rounded-xl border">⭐</button>
              <button onClick={()=>toggle(i._id, i.done)} className={`px-3 py-1 rounded-xl ${i.done? 'bg-green-600 text-white':'border'}`}>{i.done? 'Done':'Mark done'}</button>
              <button onClick={()=>del(i._id)} classNa