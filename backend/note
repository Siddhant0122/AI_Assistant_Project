// 🧪 backend/app.py
// =============================
from flask import Flask, request, jsonify, session, send_file
from flask_cors import CORS
from flask_login import LoginManager, UserMixin, login_user, login_required, logout_user, current_user
from passlib.hash import bcrypt
from pymongo import MongoClient
from dotenv import load_dotenv
from datetime import datetime
import io, os

from utils.gemini_client import ask_gemini_text, describe_image, generate_image
from utils.nlp_hooks import parse_hook
from services.expenses import add_expense, list_expenses, update_expense, delete_expense
from services.todos import add_todo, list_todos, update_todo, delete_todo
from services.reminders import add_reminder, list_reminders, update_reminder, delete_reminder
from services.dashboard import today_summary

load_dotenv()

app = Flask(__name__)
app.secret_key = os.environ.get("FLASK_SECRET", "change_me")
CORS(app, supports_credentials=True, origins=[os.environ.get("CORS_ORIGIN", "http://localhost:5173")])

# --- DB ---
client = MongoClient(os.environ.get("MONGO_URI", "mongodb://localhost:27017"))
db = client.get_database("oxta_ai" if client is None else os.environ.get("MONGO_DB", "octa_ai"))

# --- Auth (Flask-Login, session cookies; no JWT) ---
login_manager = LoginManager()
login_manager.init_app(app)

class User(UserMixin):
    def __init__(self, doc):
        self.id = str(doc["_id"])  # flask-login requires id attribute
        self.email = doc["email"]
        self.name = doc.get("name")
        self.plan = doc.get("plan", "free")

@login_manager.user_loader
def load_user(user_id):
    u = db.users.find_one({"_id": db.users._Database__client.get_default_database().codec_options.document_class.objectid(user_id)})
    # Simpler loader without ObjectId complexity:
    from bson import ObjectId
    doc = db.users.find_one({"_id": ObjectId(user_id)})
    return User(doc) if doc else None

# ---- Helpers ----
def user_doc():
    from bson import ObjectId
    return db.users.find_one({"_id": ObjectId(current_user.id)})

# ---- Auth routes ----
@app.post('/api/signup')
def signup():
    data = request.json
    email = data.get('email').lower()
    if db.users.find_one({'email': email}):
        return jsonify({'error': 'Email already in use'}), 400
    hashed = bcrypt.hash(data.get('password'))
    doc = { 'email': email, 'name': data.get('name'), 'password': hashed, 'plan': 'free', 'created_at': datetime.utcnow()}
    inserted = db.users.insert_one(doc)
    doc['_id'] = inserted.inserted_id
    login_user(User(doc))
    return jsonify({'message': 'ok'})

@app.post('/api/login')
def login():
    data = request.json
    email = data.get('email').lower()
    user = db.users.find_one({'email': email})
    if not user or not bcrypt.verify(data.get('password'), user['password']):
        return jsonify({'error': 'Invalid credentials'}), 401
    login_user(User(user))
    return jsonify({'message': 'ok'})

@app.post('/api/logout')
@login_required
def logout():
    logout_user()
    return jsonify({'message': 'ok'})

@app.get('/api/me')
@login_required
def me():
    u = user_doc()
    return jsonify({'email': u['email'], 'name': u.get('name'), 'plan': u.get('plan', 'free')})

# ---- Pricing / Mock upgrade (no real payment) ----
@app.post('/api/upgrade')
@login_required
def upgrade():
    db.users.update_one({'_id': user_doc()['_id']}, {'$set': {'plan': 'voice'}})
    return jsonify({'message': 'upgraded'})

# ---- Dashboard ----
@app.get('/api/summary/today')
@login_required
def summary_today():
    return jsonify(today_summary(db, current_user.id))

# ---- Chat (text free; voice requires plan==voice but handled on FE) ----
@app.post('/api/chat')
@login_required
def chat():
    data = request.json
    text = data.get('text','').strip()
    history = data.get('history', [])
    # Store user message
    today = datetime.utcnow().date().isoformat()
    db.chats.insert_one({ 'user_id': current_user.id, 'role': 'user', 'content': text, 'date': today, 'ts': datetime.utcnow() })

    # smart hooks: add items when user phrases include commands
    hook = parse_hook(text)
    hook_msg = None
    if hook:
        if hook['type'] == 'expense':
            add_expense(db, current_user.id, hook['item'], hook['amount'], hook['date'])
            hook_msg = f"Added expense: {hook['item']} ₹{hook['amount']} on {hook['date']}"
        elif hook['type'] == 'todo':
            add_todo(db, current_user.id, hook['title'])
            hook_msg = f"Added todo: {hook['title']}"
        elif hook['type'] == 'reminder':
            add_reminder(db, current_user.id, hook['title'], hook['date'])
            hook_msg = f"Added reminder: {hook['title']} on {hook['date']}"

    answer = ask_gemini_text(text, history)
    if hook_msg:
        answer = hook_msg + "\n\n" + answer

    db.chats.insert_one({ 'user_id': current_user.id, 'role': 'model', 'content': answer, 'date': today, 'ts': datetime.utcnow() })
    return jsonify({ 'reply': answer })

# ---- Chat history for drawer ----
@app.get('/api/chat/history')
@login_required
def chat_history():
    items = list(db.chats.find({ 'user_id': current_user.id }).sort('ts', -1).limit(100))
    for i in items:
        i['_id'] = str(i['_id'])
    return jsonify(items)

# ---- Image describe ----
@app.post('/api/image/describe')
@login_required
def image_describe():
    if 'file' not in request.files:
        return jsonify({'error': 'No image provided'}), 400
    file = request.files['file']
    text = describe_image(file.read())
    return jsonify({'description': text})

# ---- Image generate (returns PNG) ----
@app.post('/api/image/generate')
@login_required
def image_generate():
    prompt = request.json.get('prompt', '')
    img_bytes = generate_image(prompt)
    return send_file(io.BytesIO(img_bytes), mimetype='image/png')

# ---- Expenses ----
@app.get('/api/expenses')
@login_required
def expenses_list():
    items = list_expenses(db, current_user.id)
    for i in items:
        i['_id'] = str(i['_id'])
    return jsonify(items)

@app.post('/api/expenses')
@login_required
def expenses_add():
    data = request.json
    doc = add_expense(db, current_user.id, data['item'], data['amount'], data.get('date'))
    doc['_id'] = str(doc.get('_id', ''))
    return jsonify(doc)

@app.put('/api/expenses/<eid>')
@login_required
def expenses_update(eid):
    update_expense(db, current_user.id, eid, request.json)
    return jsonify({'message': 'ok'})

@app.delete('/api/expenses/<eid>')
@login_required
def expenses_delete(eid):
    delete_expense(db, current_user.id, eid)
    return jsonify({'message': 'ok'})

# ---- Todos ----
