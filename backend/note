import StatCard from '../components/StatCard'
export default function Dashboard(){
  const [sum, setSum] = useState(null)
  const nav = useNavigate()
  useEffect(()=>{ api('/api/summary/today').then(setSum) },[])
  if (!sum) return <div>Loading…</div>
  return (
    <div className="grid md:grid-cols-4 gap-4">
      <StatCard title="Chats today" value={sum.chats_today} onClick={()=>nav('/chat')} />
      <StatCard title="Expense today" value={`₹${sum.expense_today_total}`} onClick={()=>nav('/expenses')} />
      <StatCard title="Incomplete todos" value={sum.todos_incomplete} onClick={()=>nav('/todos')} />
      <StatCard title="Upcoming reminders" value={sum.next_reminders.length} onClick={()=>nav('/reminders')} />
    </div>
  )
}

// =============================
// 💬 frontend/src/pages/Chat.jsx
// =============================
import { useEffect, useRef, useState } from 'react'
import { api } from '../api'

export default function Chat(){
  const [input, setInput] = useState("")
  const [history, setHistory] = useState([])
  const [replying, setReplying] = useState(false)
  const [sttOn, setSttOn] = useState(false)
  const recRef = useRef(null)

  async function send(){
    if(!input.trim()) return
    const next = [...history, {role:'user', content: input}]
    setHistory(next)
    setInput("")
    setReplying(true)
    try{
      const res = await api('/api/chat', { method:'POST', body: JSON.stringify({ text: input, history }) })
      setHistory([...next, {role:'model', content: res.reply}])
      speak(res.reply)
    } finally { setReplying(false) }
  }

  function speak(text){
    const u = new SpeechSynthesisUtterance(text); window.speechSynthesis.cancel(); window.speechSynthesis.speak(u)
  }

  function toggleMic(){
    if(sttOn){ recRef.current?.stop(); setSttOn(false); return }
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition
    if(!SR) { alert('SpeechRecognition not supported in this browser'); return }
    const rec = new SR(); rec.lang = 'en-IN'; rec.interimResults = false; rec.maxAlternatives = 1
    rec.onresult = (e)=>{ const t = e.results[0][0].transcript; setInput(t) }
    rec.onend = ()=> setSttOn(false)
    rec.start(); recRef.current = rec; setSttOn(true)
  }

  // Image describe
  async function onDescribe(e){
    const f = e.target.files[0]; if(!f) return
    const fd = new FormData(); fd.append('file', f)
    const res = await fetch('/api/image/describe', { method:'POST', body: fd, credentials: 'include' })
    const j = await res.json(); setHistory(h=>[...h, {role:'model', content: j.description}])
  }

  // Image generate
  async function onGenerate(){
    const prompt = promptInput.current.value.trim(); if(!prompt) return
    const res = await api('/api/image/generate', { method:'POST', body: JSON.stringify({ prompt }) })
    const blob = await res.blob(); const url = URL.createObjectURL(blob)
    setHistory(h=>[...h, {role:'model', content: `Image generated:`, image:url}])
  }

  const promptInput = useRef(null)

  return (
    <div className="grid md:grid-cols-3 gap-4">
      <div className="md:col-span-2 p-4 rounded-2xl bg-white border shadow">
        <div className="h-[420px] overflow-y-auto space-y-3">
          {history.map((m,i)=> (
            <div key={i} className={`p-3 rounded-xl ${m.role==='user'? 'bg-gray-100':'bg-blue-50'}`}>
              <div className="text-xs text-gray-500">{m.role}</div>
              <div className="whitespace-pre-wrap mt-1">{m.content}</div>
              {m.image && <img src={m.image} className="mt-2 rounded-xl border" />}
            </div>
          ))}
        </div>
        <div className="mt-3 flex gap-2">
          <input className="flex-1 border p-2 rounded-xl" value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=> e.key==='Enter' && send()} placeholder="Ask anything… e.g. add expense for laptop which costs 120000 rupees" />
          <button onClick={send} className="px-4 py-2 rounded-xl bg-black text-white" disabled={replying}>Send</button>
          <button onClick={toggleMic} className={`px-3 py-2 rounded-xl border ${sttOn?'bg-green-100':'bg-white'}`}>🎙️</button>
        </div>
        <div className="mt-3 flex gap-2 items-center">
          <input ref={promptInput} className="flex-1 border p-2 rounded-xl" placeholder="Image prompt (generate)" />
          <button onClick={onGenerate} className="px-3 py-2 rounded-xl border">Generate Image</button>
          <label className="px-3 py-2 rounded-xl border cursor-pointer">Describe Image<input onChange={onDescribe} type="file" accept="image/*" hidden /></label>
        </div>
      </div>
      <div className="p-4 rounded-2xl bg-white border shadow">
        <div className="font-semibold">Tips</div>
        <ul className="list-disc pl-6 mt-2 text-sm text-gray-600 space-y-1">
          <li>Say: “add expense for laptop which costs 120000 rupees”.</li>
          <li>Say: “add a task for today to learn Python”.</li>
          <li>Say: “add a reminder for 14th September as Ayush birthday”.</li>
        </ul>
      </div>
    </div>
  )
}

