// =============================
// 🧠 backend/utils/gemini_client.py
// =============================
from google import genai
import base64
import io
from PIL import Image
import os

GEMINI_MODEL_TEXT = "gemini-2.0-flash"
GEMINI_MODEL_IMAGE = "imagen-3.0-generate"  # auto-routed by SDK if available in region

_client = None

def get_client():
    global _client
    if _client is None:
        _client = genai.Client(api_key=os.environ.get("GEMINI_API_KEY"))
    return _client


def ask_gemini_text(prompt, history=None):
    client = get_client()
    messages = []
    if history:
        # history: list of {role:"user"|"model", content:str}
        for m in history:
            messages.append({"role": m["role"], "content": m["content"]})
    messages.append({"role": "user", "content": prompt})
    resp = client.models.generate_content(model=GEMINI_MODEL_TEXT, contents=messages)
    return resp.text


def describe_image(image_bytes, prompt="Describe this image"):
    client = get_client()
    # Encode image
    b64 = base64.b64encode(image_bytes).decode("utf-8")
    part = {"inline_data": {"mime_type": "image/png", "data": b64}}
    resp = client.models.generate_content(
        model=GEMINI_MODEL_TEXT,
        contents=[{"role": "user", "content": [part, {"text": prompt}]}],
    )
    return resp.text


def generate_image(prompt):
    client = get_client()
    # Uses Images API via SDK if enabled for your key/region
    img = client.images.generate(model=GEMINI_MODEL_IMAGE, prompt=prompt)
    # returns PNG bytes
    return img._image_bytes  # SDK exposes bytes on the response

// =============================
// 🧩 backend/utils/nlp_hooks.py
// =============================
import re
from datetime import datetime

ADD_EXPENSE_PAT = re.compile(r"add\s+expense\s+for\s+(?P<item>[^,\n]+?)\s+(?:which\s+)?costs\s+(?P<amount>\d+)", re.I)
ADD_TODO_PAT = re.compile(r"add\s+(?:a\s+)?task\s+(?:for\s+today\s+)?to\s+(?P<title>.+)$", re.I)
ADD_REM_PAT = re.compile(r"add\s+a\s+reminder\s+for\s+(?P<date>\d{1,2}(?:st|nd|rd|th)?\s+[A-Za-z]+)\s+as\s+(?P<title>.+)", re.I)

MONTHS = {
  "january":1,"february":2,"march":3,"april":4,"may":5,"june":6,
  "july":7,"august":8,"september":9,"october":10,"november":11,"december":12
}

def parse_hook(user_text):
    user_text = user_text.strip()
    m = ADD_EXPENSE_PAT.search(user_text)
    if m:
        return {
            "type": "expense",
            "item": m.group("item").strip(),
            "amount": float(m.group("amount")),
            "date": datetime.utcnow().date().isoformat()
        }
    m = ADD_TODO_PAT.search(user_text)
    if m:
        return {"type": "todo", "title": m.group("title").strip(), "priority": "normal"}
    m = ADD_REM_PAT.search(user_text)
    if m:
        raw = m.group("date").lower()
        # e.g., 14th September -> 14 September
        day = int(re.sub(r"(st|nd|rd|th)", "", raw.split()[0]))
        mon = MONTHS[raw.split()[1]]
        now = datetime.utcnow()
        dt = datetime(now.year, mon, day)
        return {"type": "reminder", "title": m.group("title").strip(), "date": dt.date().isoformat()}
    return None

// =============================
// 🧾 backend/services/expenses.py
// =============================
from datetime import datetime
from bson import ObjectId

def list_expenses(db, user_id):
    return list(db.expenses.find({"user_id": user_id}).sort("date", 1))

def add_expense(db, user_id, item, amount, date=None):
    date = date or datetime.utcnow().date().isoformat()
    doc = {"user_id": user_id, "item": item, "amount": float(amount), "date": date, "created_at": datetime.utcnow()}
    db.expenses.insert_one(doc)
    return doc

def update_expense(db, user_id, expense_id, data):
    db.expenses.update_one({"_id": ObjectId(expense_id), "user_id": user_id}, {"$set": data})

def delete_expense(db, user_id, expense_id):
    db.expenses.delete_one({"_id": ObjectId(expense_id), "user_id": user_id})

// =============================
// ✅ backend/services/todos.py
// =============================
from datetime import datetime
from bson import ObjectId

def list_todos(db, user_id):
    return list(db.todos.find({"user_id": user_id}).sort([("favourite", -1), ("priority", -1), ("created_at", 1)]))

def add_todo(db, user_id, title, priority="normal", favourite=False, due_date=None):
    doc = {"user_id": user_id, "title": title, "priority": priority, "favourite": favourite, "done": False, "due_date": due_date, "created_at": datetime.utcnow()}
    db.todos.insert_one(doc)
    return doc

def update_todo(db, user_id, todo_id, data):
    db.todos.update_one({"_id": ObjectId(todo_id), "user_id": user_id}, {"$set": data})

def delete_todo(db, user_id, todo_id):
    db.todos.delete_one({"_id": ObjectId(todo_id), "user_id": user_id})

// =============================
// ⏰ backend/services/reminders.py
// =============================
from datetime import datetime
from bson import ObjectId

def list_reminders(db, user_id):
    return list(db.reminders.find({"user_id": user_id}).sort("date", 1))

def add_reminder(db, user_id, title, date):
    doc = {"user_id": user_id, "title": title, "date": date, "created_at": datetime.utcnow()}
    db.reminders.insert_one(doc)
    return doc

def update_reminder(db, user_id, rid, data):
    db.reminders.update_one({"_id": ObjectId(rid), "user_id": user_id}, {"$set": data})

def delete_reminder(db, user_id, rid):
    db.reminders.delete_one({"_id": ObjectId(rid), "user_id": user_id})

// =============================
// 📊 backend/services/dashboard.py
// =============================
from datetime import datetime

def today_summary(db, user_id):
    today = datetime.utcnow().date().isoformat()
    chats = db.chats.count_documents({"user_id": user_id, "date": today})
    expenses = list(db.expenses.find({"user_id": user_id, "date": today}))
    todos_incomplete = db.todos.count_documents({"user_id": user_id, "done": False})
    upcoming = list(db.reminders.find({"user_id": user_id, "date": {"$gte": today}}).sort("date", 1).limit(3))
    return {
        "chats_today": chats,
        "expense_today_total": sum(e.get("amount", 0) for e in expenses),
        "todos_incomplete": int(todos_incomplete),
        "next_reminders": upcoming,
    }

