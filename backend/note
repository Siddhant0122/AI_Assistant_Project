// 🧱 frontend/src/components/ChatHistoryDrawer.jsx
// =============================
import { useEffect, useState } from 'react'
import { api } from '../api'
export default function ChatHistoryDrawer({ open }) {
  const [items, setItems] = useState([])
  useEffect(()=>{ if(open){ api('/api/chat/history').then(setItems).catch(()=>{}) } },[open])
  return (
    <div className={`fixed top-0 left-0 h-full w-80 bg-white border-r shadow transition-transform ${open? 'translate-x-0':'-translate-x-full'}`}>
      <div className="p-4 font-semibold border-b">History</div>
      <div className="p-3 space-y-2 overflow-y-auto h-[calc(100%-3rem)]">
        {items.map(i=> (
          <div key={i._id} className="text-sm p-2 rounded-lg border">
            <div className="text-gray-500">{new Date(i.ts).toLocaleString()}</div>
            <div className={`mt-1 ${i.role==='user'?'':'text-blue-700'}`}>{i.content.slice(0,140)}</div>
          </div>
        ))}
      </div>
    </div>
  )
}

