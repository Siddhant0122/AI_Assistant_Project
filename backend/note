      <div className="text-gray-500 text-sm">{title}</div>
      <div className="text-2xl font-semibold mt-2">{value}</div>
    </div>
  )
}

// =============================
// 📊 frontend/src/components/Chart.jsx
// =============================
import { useEffect, useRef } from 'react'
export default function Chart({ data }) {
  const canvasRef = useRef()
  useEffect(() => {
    const ctx = canvasRef.current.getContext('2d')
    // Simple vanilla chart (no external lib)
    ctx.clearRect(0,0,800,300)
    const w = canvasRef.current.width, h = canvasRef.current.height
    const pad = 30
    const xs = data.map((d,i)=> i)
    const ys = data.map(d=> d.amount)
    const maxY = Math.max(1,...ys)
    ctx.beginPath(); ctx.moveTo(pad,h-pad)
    ctx.strokeStyle = '#333'
    ctx.lineTo(w-pad,h-pad); ctx.lineTo(w-pad,pad); ctx.stroke()
    ctx.strokeStyle = '#2563eb'
    ctx.beginPath()
    data.forEach((d,i)=>{
      const x = pad + (i*(w-2*pad)/Math.max(1,(data.length-1)))
      const y = h-pad - (d.amount/maxY)*(h-2*pad)
      i===0? ctx.moveTo(x,y): ctx.lineTo(x,y)
    })
    ctx.stroke()
  }, [data])
  return (<canvas ref={canvasRef} width="800" height="300" className="w-full"></canvas>)
}

