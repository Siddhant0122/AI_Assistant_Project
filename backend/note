  return (
    <form onSubmit={submit} className="max-w-sm mx-auto bg-white p-6 rounded-2xl shadow border">
      <h2 className="text-xl font-semibold">Login</h2>
      <input className="mt-4 w-full border p-2 rounded-xl" placeholder="Email" value={form.email} onChange={e=>setForm({...form, email:e.target.value})} />
      <input type="password" className="mt-2 w-full border p-2 rounded-xl" placeholder="Password" value={form.password} onChange={e=>setForm({...form, password:e.target.value})} />
      <button className="mt-4 w-full bg-black text-white px-4 py-2 rounded-xl">Login</button>
      <div className="text-sm mt-3 text-center">No account? <Link className="underline" to="/signup">Sign up</Link></div>
    </form>
  )
}

